{
  "manifest_version": 3,
  "name": "iKaptchaSolve",
  "version": "1.0",
  "description": "Auto-solves Ikariam piracy and demolition captchas",
  "permissions": ["offscreen"],
  "host_permissions": ["*://*.ikariam.gameforge.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.ikariam.gameforge.com/*"],
      "exclude_matches": ["*://forum.ikariam.gameforge.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["model/model.onnx", "dist/*"],
      "matches": ["*://*.ikariam.gameforge.com/*"],
      "exclude_matches": ["*://forum.ikariam.gameforge.com/*"]
    }
  ]
}
